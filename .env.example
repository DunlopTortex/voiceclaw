GEMINI_API_KEY=your-gemini-api-key-from-aistudio

# Coding provider: "claude" (default), "ollama", or "zed"
CODING_PROVIDER=claude

# Ollama settings (when using CODING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Z.ai settings (when using CODING_PROVIDER=zed)
# ZED_API_KEY=your-zed-api-key
# ZED_API_URL=https://api.zed.dev/ai/v1
# ZED_MODEL=zed-1
